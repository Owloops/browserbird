{
  "mcpServers": {
    "playwright": {
      "command": "playwright-mcp",
      "args": ["--config", "docker/config/browserbird/playwright.config.json"],
      "env": {
        "WAYLAND_DISPLAY": "wayland-1",
        "XDG_RUNTIME_DIR": "/tmp/xdg-runtime-bbuser",
        "PLAYWRIGHT_BROWSERS_PATH": "/home/bbuser/.cache/ms-playwright"
      }
    }
  }
}
