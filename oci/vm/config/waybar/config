{
    "layer": "top",
    "position": "bottom",
    "height": 40,
    "margin-bottom": 7,
    "margin-left": 9,
    "margin-right": 9,
    "modules-left": ["custom/chromium", "custom/terminal", "sway/workspaces"],
    "modules-center": ["sway/window"],
    "modules-right": ["clock"],
    "sway/workspaces": {
        "disable-scroll": true
    },
    "sway/window": {
        "max-length": 70
    },
    "clock": {
        "format": "{:%H:%M}",
        "format-alt": "{:%Y-%m-%d %H:%M:%S}",
        "interval": 1,
        "tooltip": false
    },
    "custom/chromium": {
        "format": "\uf0ac",
        "on-click": "chromium --disable-gpu --no-sandbox --disable-dev-shm-usage --ozone-platform=wayland",
        "tooltip": false
    },
    "custom/terminal": {
        "format": "\uf120",
        "on-click": "foot",
        "tooltip": false
    }
}
