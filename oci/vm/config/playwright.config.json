{
  "browser": {
    "browserName": "chromium",
    "launchOptions": {
      "args": [
        "--disable-gpu",
        "--disable-software-rasterizer",
        "--in-process-gpu",
        "--no-sandbox",
        "--disable-dev-shm-usage",
        "--ozone-platform=wayland",
        "--disable-blink-features=AutomationControlled"
      ]
    }
  }
}
